generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NewsCategory {
  ACTUALITE
  NANEYE_YARDA
  CENTENAIRE
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model Actualite {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String
  content        String?
  featuredImage  String?
  category       NewsCategory  @default(ACTUALITE)
  status         ContentStatus @default(PUBLISHED)
  location       String
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  publishedAt    DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  gallery        ActualiteGalleryImage[]

  @@index([category, publishedAt])
  @@index([status, publishedAt])
}

model ActualiteGalleryImage {
  id         String   @id @default(cuid())
  actualiteId String
  imagePath  String
  caption    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  actualite  Actualite @relation(fields: [actualiteId], references: [id], onDelete: Cascade)

  @@index([actualiteId, sortOrder])
}

model Event {
  id             String            @id @default(cuid())
  title          String
  slug           String            @unique
  detail         String
  featuredImage  String?
  location       String
  latitude       Float?
  longitude      Float?
  status         ContentStatus     @default(PUBLISHED)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  startAt        DateTime
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  gallery        EventGalleryImage[]

  @@index([startAt])
  @@index([status, startAt])
}

model EventGalleryImage {
  id        String   @id @default(cuid())
  eventId   String
  imagePath String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, sortOrder])
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AdminUser {
  id           String      @id @default(cuid())
  fullName     String
  email        String      @unique
  passwordHash String
  role         AdminRole   @default(EDITOR)
  isActive     Boolean     @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  activityLogs ActivityLog[]
}

model ActivityLog {
  id          String    @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  details     String?
  actorName   String
  actorRole   String
  actorUserId String?
  createdAt   DateTime  @default(now())
  actorUser   AdminUser? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType, createdAt])
}

model MediaAsset {
  id        String   @id @default(cuid())
  title     String
  altText   String?
  filePath  String   @unique
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomepageConfig {
  id             String   @id @default("main")
  heroBadge      String   @default("Ville de Niamey")
  heroTitle      String   @default("Une plateforme moderne pour suivre la vie de votre ville.")
  heroSubtitle   String   @default("Suivez l'actualité municipale, les actions Naneye Yarda, le programme du centenaire et les services de contact de la mairie dans une interface claire, rapide et animée.")
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  updatedAt      DateTime @updatedAt
}

model SliderItem {
  id          String   @id @default(cuid())
  title       String
  description String
  imagePath   String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model SiteSettings {
  id                String   @id @default("main")
  siteName          String   @default("Ville de Niamey")
  siteLogoPath      String?
  faviconPath       String?
  smtpHost          String?
  smtpPort          Int?
  smtpUser          String?
  smtpPassword      String?
  smtpFromEmail     String?
  smtpFromName      String?
  footerText        String?
  googleAnalyticsId String?
  updatedAt         DateTime @updatedAt
}

model CentenaireConfig {
  id                     String   @id @default("main")
  heroBadge              String
  heroTitle              String
  heroIntro              String
  heroImagePath          String
  heroImageEyebrow       String
  heroImageCaption       String
  keyFactsLines          String
  milestonesEyebrow      String
  milestonesTitle        String
  milestonesLines        String
  themeEyebrow           String
  themeTitle             String
  themeDescription       String
  objectivesEyebrow      String
  objectivesTitle        String
  objectivesLines        String
  axesEyebrow            String
  axesTitle              String
  strategicAxesLines     String
  agendaEyebrow          String
  agendaTitle            String
  agendaSubtitle         String
  annualAgendaLines      String
  galleryEyebrow         String
  galleryTitle           String
  galleryLines           String
  heroPrimaryCtaLabel    String
  heroPrimaryCtaHref     String
  heroSecondaryCtaLabel  String
  heroSecondaryCtaHref   String
  galleryPrimaryCtaLabel String
  galleryPrimaryCtaHref  String
  gallerySecondaryCtaLabel String
  gallerySecondaryCtaHref  String
  seoTitle               String?
  seoDescription         String?
  seoKeywords            String?
  updatedAt              DateTime @updatedAt
}
